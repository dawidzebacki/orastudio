---
// ORA.studio — Nav (Krok 9 + Krok 16: burger na mobile)
// Globalna nawigacja: marka = pełny wordmark Z FALĄ (Logo) + linki. Pasek sticky.
// Linki z site.ts — TYLKO P1 (istniejące podstrony), bez Polityki (ta w stopce).
// Mobile (< 56rem): burger z DOSTĘPNYM przełącznikiem (aria-expanded/-controls),
// panel rozwijany pod paskiem. Minimalny JS (progresywne wzmocnienie + aria).
import { nav } from '../data/site';
import Logo from './Logo.astro';

const links = nav.filter((n) => n.priority === 'P1' && n.href !== '/polityka-prywatnosci');

// Bieżąca ścieżka bez końcowego „/" — do aria-current (build daje /kontakt/).
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="nav">
  <div class="nav__inner container">
    <Logo height="1.7rem" />

    <div class="nav__actions">
      <nav id="nav-menu" class="nav__menu" aria-label="Główna nawigacja">
        <ul class="nav__list" role="list">
          {links.map((l) => (
            <li>
              <a
                class="nav__link"
                href={l.href}
                aria-current={current === l.href ? 'page' : undefined}
              >{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Przełącznik motywu (Krok 17). Ikona = motyw DOCELOWY: w jasnym widać
          księżyc (→ ciemny), w ciemnym słońce (→ jasny). aria-pressed = czy ciemny. */}
      <button
        type="button"
        class="nav__theme"
        aria-label="Przełącz motyw jasny i ciemny"
        aria-pressed="false"
        title="Motyw jasny / ciemny"
      >
        <svg class="nav__icon nav__icon--moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" /></svg>
        <svg class="nav__icon nav__icon--sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" /></svg>
      </button>

      <button
        type="button"
        class="nav__toggle"
        aria-label="Menu nawigacji"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="nav__burger" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<style>
  /* Pasek przyklejony przy scrollu — zawsze widoczny. Tło kremowe, hairline u dołu.
     z-index pod skip-linkiem (10). Sticky = pozycjonowany → kotwica dla panelu mobile. */
  .nav {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--c-cream);
    border-bottom: 1px solid var(--c-ink-15);
  }
  .nav__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-s) var(--space-l);
    padding-block: var(--space-m);
  }

  /* Prawy klaster: menu (desktop inline) + przełącznik motywu + burger (mobile).
     Na mobile menu staje się panelem absolutnym (poza flow) → w rzędzie zostają
     przełącznik motywu i burger. */
  .nav__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-m);
  }

  /* --- Przełącznik motywu (jasny/ciemny) ------------------------------- */
  .nav__theme {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    background: transparent;
    border: 1px solid var(--c-ink-15);
    border-radius: var(--radius);
    color: var(--c-ink-70);
    cursor: pointer;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .nav__theme:hover {
    color: var(--c-ink);
    border-color: var(--c-ink-45);
  }
  .nav__icon {
    display: block;
  }
  /* Ikona = motyw DOCELOWY. Jasny → księżyc; ciemny → słońce. */
  .nav__icon--sun {
    display: none;
  }
  :global(html[data-theme='dark']) .nav__icon--moon {
    display: none;
  }
  :global(html[data-theme='dark']) .nav__icon--sun {
    display: block;
  }

  /* Linki — etykiety KAPITALIKI (warstwa strukturalna). */
  .nav__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-m);
    margin: 0;
  }
  .nav__link {
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-ink-70);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }
  .nav__link:hover {
    color: var(--c-ink);
  }
  /* Bieżąca strona — atrament + cienkie podkreślenie (neutralnie, bez bursztynu). */
  .nav__link[aria-current='page'] {
    color: var(--c-ink);
    text-decoration: underline;
    text-underline-offset: 0.4em;
    text-decoration-thickness: 1px;
  }

  /* --- Burger (przełącznik) — domyślnie ukryty (desktop) ---------------- */
  .nav__toggle {
    display: none;
    width: 2.4rem;                /* zunifikowane z .nav__theme */
    height: 2.4rem;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--c-ink-15);
    border-radius: var(--radius);
    cursor: pointer;
  }
  /* Ikona z 3 kresek (środkowa = sama .nav__burger, skrajne = ::before/::after). */
  .nav__burger,
  .nav__burger::before,
  .nav__burger::after {
    display: block;
    width: 1.25rem;
    height: 2px;                  /* pełny piksel — wszystkie 3 kreski tej samej grubości */
    background: var(--c-ink);
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav__burger {
    position: relative;
  }
  .nav__burger::before,
  .nav__burger::after {
    content: '';
    position: absolute;
    left: 0;
  }
  .nav__burger::before { top: -6px; }
  .nav__burger::after { top: 6px; }

  /* --- Mobile (< 56rem): pokaż burger, schowaj menu do rozwijanego panelu -- */
  @media (max-width: 56rem) {
    .nav__toggle {
      display: inline-flex;
    }

    .nav__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--c-cream);
      border-bottom: 1px solid var(--c-ink-15);
      padding-block: var(--space-m);
    }
    .nav--open .nav__menu {
      display: block;
    }

    .nav__list {
      flex-direction: column;
      gap: var(--space-s);
      padding-inline: clamp(1.25rem, 5vw, 3rem);   /* wyrównanie do logo (.container) */
    }
    .nav__link {
      display: block;
      padding-block: var(--space-2xs);
    }

    /* Burger → X po otwarciu (miękko). */
    .nav--open .nav__burger {
      background: transparent;
    }
    .nav--open .nav__burger::before {
      transform: translateY(6px) rotate(45deg);
    }
    .nav--open .nav__burger::after {
      transform: translateY(-6px) rotate(-45deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__burger,
    .nav__burger::before,
    .nav__burger::after { transition: none; }
  }
</style>

<script>
  const header = document.querySelector('.nav') as HTMLElement | null;
  const toggle = header?.querySelector('.nav__toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('nav-menu');

  if (header && toggle && menu) {
    const setOpen = (open: boolean) => {
      header.classList.toggle('nav--open', open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    toggle.addEventListener('click', () => {
      setOpen(!header.classList.contains('nav--open'));
    });

    // Zamknij po kliknięciu w link (nawigacja na tej samej / nowej stronie).
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    // Esc zamyka panel.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }

  // --- Przełącznik motywu (jasny/ciemny) -------------------------------
  // Stan początkowy data-theme ustawia skrypt no-flash w <head> (BaseLayout).
  // Tu tylko reagujemy na klik: zapis wyboru + aktualizacja aria + theme-color.
  const themeBtn = header?.querySelector('.nav__theme') as HTMLButtonElement | null;
  if (themeBtn) {
    const root = document.documentElement;
    const meta = document.querySelector('meta[name="theme-color"]');

    const syncTheme = (theme: string) => {
      themeBtn.setAttribute('aria-pressed', String(theme === 'dark'));
      if (meta) meta.setAttribute('content', theme === 'dark' ? '#1c1611' : '#f3eadb');
    };

    syncTheme(root.dataset.theme || 'light');

    themeBtn.addEventListener('click', () => {
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try { localStorage.setItem('ora-theme', next); } catch (e) {}
      syncTheme(next);
    });
  }
</script>
