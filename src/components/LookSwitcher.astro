---
// ORA.studio — LookSwitcher (Krok 10, sekcja 4.4 mapy — „Jeden look")
// Przełącznik tonacji jednego kadru: Ciepły / Chłodny / Czarno-biały.
// CSS-ONLY (radio + :checked + ~), BEZ JS — zgodnie z zakazem ciężkich
// animacji/WebGL. Ruch wolny i miękki (przejście filtra). Kadr trzyma język
// passe-partout (mata + bevel + wpuszczenie), bez drop-shadow wokół ramki.
//
// Tonacje to FILTRY na placeholderze (portfolio startuje bez zdjęć): ciepły =
// lekki bursztyn/sepia, chłodny = stonowany chłód, cz-b = desaturacja.
// Po wstawieniu realnego zdjęcia (prop `src`) filtry działają tak samo.

interface Props {
  /** Nagłówek sekcji [22–40 zn]. */
  heading: string;
  /** Lede pod nagłówkiem [90–140 zn]. */
  lede?: string;
  /** Ścieżka do zdjęcia. Brak = tonalny placeholder. */
  src?: string;
  /** Tekst alternatywny kadru (a11y). */
  alt?: string;
  /** Proporcje kadru. */
  ratio?: string;
  /** Wariant tonalny placeholdera (1–3). */
  tone?: 1 | 2 | 3;
  /** Nazwa grupy radio — MUSI być unikalna na stronie (kilka instancji). */
  name?: string;
  class?: string;
}

const {
  heading,
  lede,
  src,
  alt = '',
  ratio = '4 / 5',
  tone = 2,
  name = 'look',
  class: className = '',
} = Astro.props;

// Trzy looki z briefu (4.4). `id` namespaced nazwą grupy (unikalność radio + for).
const looks = [
  { id: `${name}-warm`, value: 'warm', label: 'Ciepły' },
  { id: `${name}-cool`, value: 'cool', label: 'Chłodny' },
  { id: `${name}-bw`, value: 'bw', label: 'Czarno-biały' },
];
const captionId = `${name}-cap`;
---

<div class={`look ${className}`.trim()} style={`--look-ratio: ${ratio};`}>
  <div class="look__intro">
    <h2 class="look__heading">{heading}</h2>
    {lede && <p class="look__lede">{lede}</p>}
  </div>

  {/* Stan przełącznika — radia ukryte wizualnie, sterują kadrem przez `~`.
      Pierwsze (Ciepły) domyślnie zaznaczone: look on-brand „ciepły analog". */}
  {looks.map((l, i) => (
    <input
      class="look__radio visually-hidden"
      type="radio"
      name={name}
      id={l.id}
      value={l.value}
      checked={i === 0}
    />
  ))}

  {/* Segmentowany przełącznik — etykiety KAPITALIKI (warstwa strukturalna). */}
  <div class="look__controls" role="group" aria-label="Wybór tonacji kadru">
    {looks.map((l) => (
      <label class="look__btn" for={l.id}>{l.label}</label>
    ))}
  </div>

  {/* Kadr w macie passe-partout — tonacja zmieniana filtrem wg zaznaczenia. */}
  <figure class="look__stage" aria-describedby={captionId}>
    <div class="look__mat">
      <div class="look__window" data-tone={tone}>
        {src
          ? <img class="look__photo" src={src} alt={alt} loading="lazy" decoding="async" />
          : <div class="look__photo look__placeholder" role="img" aria-label={alt || 'Kadr — placeholder'}></div>
        }
        <span class="look__inset" aria-hidden="true"></span>
      </div>
    </div>
    <figcaption id={captionId} class="look__cap" aria-live="polite">
      <span class="look__cap-warm">I · Ciepły</span>
      <span class="look__cap-cool">I · Chłodny</span>
      <span class="look__cap-bw">I · Czarno-biały</span>
    </figcaption>
  </figure>
</div>

<style>
  .look {
    display: grid;
    gap: var(--space-l);
    max-width: 34rem;
  }
  .look__intro {
    max-width: var(--measure);
  }
  .look__heading {
    font-size: var(--fs-h2);
  }
  .look__lede {
    margin-top: var(--space-s);
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }

  /* --- Segmentowany przełącznik (etykiety klikalne, radia ukryte) -------- */
  .look__controls {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 1px;                       /* hairline między segmentami */
    background: var(--c-ink-15);    /* prześwit = linia działowa */
    border: 1px solid var(--c-ink-15);
    border-radius: var(--radius);
    overflow: hidden;
    width: fit-content;
  }
  .look__btn {
    padding: 0.6em 1.1em;
    background: var(--c-mat);
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-ink-70);
    cursor: pointer;
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .look__btn:hover {
    color: var(--c-ink);
  }

  /* --- Kadr passe-partout (język Gallery) -------------------------------- */
  .look__mat {
    position: relative;
    background-color: var(--c-mat);
    --pp-pad: clamp(1.4rem, 4.5%, 2.75rem);
    padding: var(--pp-pad);
    padding-bottom: calc(var(--pp-pad) * 1.18);
    border-radius: var(--radius);
    isolation: isolate;
  }
  .look__mat::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: url('../styles/paper-grain.svg');
    background-size: 320px 320px;
    background-repeat: repeat;
    opacity: 0.07;
    mix-blend-mode: multiply;
    border-radius: inherit;
  }
  .look__window {
    position: relative;
    z-index: 1;
    aspect-ratio: var(--look-ratio);
    border-style: solid;
    border-width: 5px;
    border-color:
      color-mix(in srgb, #ffffff 62%, transparent)
      color-mix(in srgb, var(--c-ink) 16%, transparent)
      color-mix(in srgb, var(--c-ink) 16%, transparent)
      color-mix(in srgb, #ffffff 62%, transparent);
    border-radius: var(--radius);
    background-color: var(--c-ink-15);
  }
  .look__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 1px;
    /* Miękkie przejście tonacji — wolno i bez gwałtownego błysku. */
    transition: filter calc(var(--dur) * 2.4) var(--ease);
  }
  @media (prefers-reduced-motion: reduce) {
    .look__photo { transition: none; }
  }
  .look__placeholder {
    background:
      linear-gradient(
        118deg,
        color-mix(in srgb, var(--c-ink) 40%, var(--c-cream)),
        color-mix(in srgb, var(--c-ink) 16%, var(--c-cream))
      );
  }
  .look__window[data-tone='1'] .look__placeholder {
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--c-ink) 52%, var(--c-cream)),
        color-mix(in srgb, var(--c-ink) 24%, var(--c-cream))
      );
  }
  .look__window[data-tone='3'] .look__placeholder {
    background:
      linear-gradient(
        152deg,
        color-mix(in srgb, var(--c-ink) 62%, var(--c-cream)),
        color-mix(in srgb, var(--c-ink) 30%, var(--c-cream))
      );
  }
  .look__inset {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 1px;
    box-shadow:
      inset 0 7px 9px -5px color-mix(in srgb, var(--c-ink) 42%, transparent);
  }

  /* --- Podpis: pokazujemy wariant odpowiadający zaznaczeniu --------------- */
  .look__cap {
    display: flex;
    align-items: baseline;
    margin-top: var(--space-xs);
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--c-ink-70);
  }
  .look__cap > span { display: none; }

  /* =======================================================================
     STAN — sterowanie kadrem i przełącznikiem przez zaznaczone radio.
     Radia poprzedzają .look__controls i .look__stage w DOM → kombinator `~`.
     Filtry: ciepły = lekka sepia/bursztyn, chłodny = stonowany chłód
     (hue lekko w stronę cienia), cz-b = pełna desaturacja.
     ===================================================================== */

  /* Ciepły */
  .look__radio[value='warm']:checked ~ .look__stage .look__photo {
    filter: sepia(0.32) saturate(1.06) hue-rotate(-8deg) brightness(1.02);
  }
  /* Chłodny */
  .look__radio[value='cool']:checked ~ .look__stage .look__photo {
    filter: saturate(0.82) hue-rotate(14deg) brightness(1.03) contrast(1.02);
  }
  /* Czarno-biały */
  .look__radio[value='bw']:checked ~ .look__stage .look__photo {
    filter: grayscale(1) contrast(1.05) brightness(1.01);
  }

  /* Aktywny segment przełącznika — atrament na macie (neutralnie, bez bursztynu;
     akcent widoku niesie kropka logo / numery gdzie indziej). */
  .look__radio[value='warm']:checked ~ .look__controls .look__btn[for$='-warm'],
  .look__radio[value='cool']:checked ~ .look__controls .look__btn[for$='-cool'],
  .look__radio[value='bw']:checked ~ .look__controls .look__btn[for$='-bw'] {
    background: var(--c-ink);
    color: var(--c-cream);
  }

  /* Podpis — pokaż linijkę zgodną z zaznaczeniem. */
  .look__radio[value='warm']:checked ~ .look__stage .look__cap-warm,
  .look__radio[value='cool']:checked ~ .look__stage .look__cap-cool,
  .look__radio[value='bw']:checked ~ .look__stage .look__cap-bw {
    display: inline;
  }

  /* Focus widoczny — fokus na ukrytym radiu maluje obrys na JEGO etykiecie. */
  .look__radio[value='warm']:focus-visible ~ .look__controls .look__btn[for$='-warm'],
  .look__radio[value='cool']:focus-visible ~ .look__controls .look__btn[for$='-cool'],
  .look__radio[value='bw']:focus-visible ~ .look__controls .look__btn[for$='-bw'] {
    outline: 2px solid var(--c-amber);
    outline-offset: -2px;
  }
</style>
