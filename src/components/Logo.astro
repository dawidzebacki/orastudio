---
// ORA.studio — Logo (Krok 9, korekta Ady)
// Pełny wordmark „ORA.studio" Z FALĄ jako jeden znak (zamiast sygnet + osobny tekst).
// Źródło: wordmark-ink.svg — pełne KRZYWE (web-safe, bez zależności od QuincyCF),
// litery atrament + kropka bursztyn. Link do strony głównej.
import { site } from '../data/site';

interface Props {
  /** Wysokość znaku (CSS), np. "1.75rem". Szerokość auto (proporcja 5:1). */
  height?: string;
  class?: string;
}
const { height = '1.6rem', class: className = '' } = Astro.props;
---

<a class={`logo ${className}`.trim()} href="/" aria-label={`${site.brand} — strona główna`} style={`--logo-h: ${height};`}>
  {/* Dwa warianty krzywych — atrament (jasny motyw) / krem (ciemny). Oba mają
      bursztynową kropkę (sygnatura). Przełączane przez data-theme (Krok 17). */}
  <img class="logo__img logo__img--ink" src="/logo/wordmark-ink.svg" alt="" width="1000" height="200" decoding="async" />
  <img class="logo__img logo__img--cream" src="/logo/wordmark-transparent-cream.svg" alt="" width="1000" height="200" decoding="async" />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo__img {
    height: var(--logo-h, 1.6rem);
    width: auto;
  }
  /* Domyślnie (jasny motyw): atramentowy wordmark; kremowy ukryty. */
  .logo__img--cream {
    display: none;
  }
  :global(html[data-theme='dark']) .logo__img--ink {
    display: none;
  }
  :global(html[data-theme='dark']) .logo__img--cream {
    display: block;
  }
</style>
