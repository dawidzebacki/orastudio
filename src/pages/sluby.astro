---
// ORA.studio — Śluby (early bird 2026) · P2 · Krok 10
// Złożona z gotowych komponentów wg sekcji 4 mapy treści (4.1–4.8).
// Adresat: pary kameralne / cywilne — nabór par założycielskich (early bird).
// SEO (naturalnie, nie listą): fotograf ślub cywilny · kameralny ślub · reportaż ślubny Trójmiasto.
// Treść = lorem w długościach z mapy (sekcja 1). Tytuły kroków = realne (mapa 4.3). Dane realne z site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cards from '../components/Cards.astro';
import Process from '../components/Process.astro';
import LookSwitcher from '../components/LookSwitcher.astro';
import Gallery from '../components/Gallery.astro';
import Faq from '../components/Faq.astro';
import Form from '../components/Form.astro';
import { placeholderImg } from '../utils/placeholder';

// Ramki na zdjęcia (Hero, LookSwitcher, galeria) = na razie NIEWIDOCZNE — decyzja
// Ady (Krok 23). Przełącz na `true` (lub usuń bramki), gdy wejdą realne kadry.
const showFrames = false;

// 4.2 — „co zawiera" early bird (3 punkty). Treści realne (ORA_tresci). Numeracja rzymska.
const includes = [
  { title: 'Pełny reportaż, nie skrót', desc: 'Wasz ślub fotografuję tak samo uważnie jak każdy inny. Early bird dotyczy wyłącznie ceny, nie zaangażowania.' },
  { title: 'Zdjęcia w 24 godziny', desc: 'Obrobiony komplet dostajecie następnego dnia, dokładnie jak w standardowej ofercie.' },
  { title: 'Kilka kadrów do portfolio', desc: 'Proszę jedynie o zgodę na pokazanie wybranych zdjęć.' },
];

// 4.3 — jak to działa (3 kroki). Treści realne (ORA_tresci). III = „Dostawa 24h".
const steps = [
  { title: 'Wybór looku', desc: 'Przed ślubem podczas godzinnych konsultacji wybieracie jeden klimat zdjęć. Trzymam się go na całej serii, więc album jest spójny.' },
  { title: 'Reportaż (3h)', desc: 'W umówionym czasie jestem obok i dokumentuję najważniejsze chwile - przygotowania, ceremonię, pierwsze emocje. Dyskretnie, bez ustawiania.' },
  { title: 'Dostawa 24h', desc: 'Obrobiony komplet macie następnego dnia. Bez czekania miesiącami, kiedy wspomnienia zdążą już wyblaknąć.' },
];

// 4.5 — galeria śluby (6 kadrów). Podpisy „para · miejsce" (mapa 4.5), tonacje/proporcje mieszane.
const frames = [
  { numeral: 'I', place: 'Aleksandra & Marek', ratio: '4 / 5', tone: 1 },
  { numeral: 'II', place: 'Zofia & Jan', ratio: '1 / 1', tone: 2 },
  { numeral: 'III', place: 'Hanna & Piotr', ratio: '3 / 2', tone: 3 },
  { numeral: 'IV', place: 'Maria & Tomasz', ratio: '4 / 5', tone: 2 },
  { numeral: 'V', place: 'Julia & Kacper', ratio: '1 / 1', tone: 1 },
  { numeral: 'VI', place: 'Nina & Wojciech', ratio: '3 / 2', tone: 3 },
] as const;

// 4.7 — FAQ mini (4 pytania). Treści realne (ORA_copy_calosc, sekcja Śluby).
const faq = [
  { q: 'Czy fotografujesz śluby cywilne i humanistyczne?', a: 'Tak, jak najbardziej. Kameralne śluby cywilne i humanistyczne świetnie pasują do dokumentalnego stylu - jest w nich dużo naturalnych, spontanicznych chwil.' },
  { q: 'Na czym polega oferta early bird?', a: 'Kompletuję portfolio, więc kilka par z sezonu 2026 fotografuję w symbolicznej cenie w zamian za zgodę na pokazanie wybranych kadrów. Reportaż i dostawa w 24 godziny są dokładnie takie same jak w ofercie standardowej.' },
  { q: 'Kiedy dostaniemy zdjęcia ze ślubu?', a: 'Najpóźniej następnego dnia. Obrobiony komplet wysyłam do 24 godzin, żebyście mogli wrócić do tych chwil, zanim emocje opadną.' },
  { q: 'Czy dojeżdżasz poza Trójmiasto?', a: 'Tak. Bazuję w Gdańsku, Gdyni i Sopocie, a na śluby dojeżdżam w promieniu około 50 km. Jeśli miejsce leży dalej - napiszcie, zwykle da się to ustalić.' },
];

// 4.8 — pola formularza rezerwacji (imię · e-mail · data ślubu · miejsce · wiadomość).
const bookingFields = [
  { name: 'name', label: 'Imię', type: 'text', required: true, half: true },
  { name: 'email', label: 'E-mail', as: 'input', type: 'email', required: true, half: true },
  { name: 'date', label: 'Data ślubu', as: 'input', type: 'date', half: true },
  { name: 'place', label: 'Miejsce', type: 'text', half: true },
  { name: 'message', label: 'Wiadomość', as: 'textarea', required: true },
] as const;
---

<BaseLayout
  title="Fotograf na ślub cywilny i kameralny - early bird 2026 | ORA.studio"
  rawTitle
  description="Kameralny reportaż ślubny w Trójmieście - nabór par założycielskich na 2026. Jeden look, dyskretny dokument, gotowe zdjęcia w 24 godziny."
  path="/sluby"
>
  <main>
    {/* 4.1 — HERO -------------------------------------------------------- */}
    <section class="sec sec--hero container">
      <Hero
        as="h1"
        eyebrow="Reportaż ślubny · Trójmiasto"
        lead="te prawdziwe"
        title="chwile."
        lede="Fotografuję śluby w Trójmieście tak, jak je przeżywacie - bez pozowania godzinami, sztywnych póz i nienaturalnych uśmiechów. Komplet zdjęć dostajecie następnego dnia, kiedy emocje są jeszcze świeże."
        primary={{ label: 'Zapisz się - early bird', href: '#zapis' }}
        secondary={showFrames ? { label: 'Zobacz galerie', href: '#galeria' } : undefined}
        image={showFrames ? { numeral: 'I', place: 'Sopot', alt: 'Placeholder — kadr otwierający ze ślubu', ratio: '4 / 5' } : undefined}
      />
    </section>

    {/* 4.2a — EARLY BIRD · STATEMENT (proza) — PAS AKCENTOWY (terakota + fala) */}
    <section class="sec band-accent" aria-labelledby="s-early">
      <div class="container">
        <p class="eyebrow">Nabór par założycielskich</p>
        <div class="prose">
          <h2 id="s-early">Szukam par na pierwsze śluby sezonu 2026</h2>
          <p>
            Zaczynam swoją drogę z fotografią ślubną i kompletuję portfolio, dlatego zapraszam kilka par
            założycielskich. W cenie early bird fotografuję Wasz dzień na pełnych zasadach: ten sam
            dokumentalny styl, wcześniej wybrany klimat i zdjęcia w 24 godziny. W zamian proszę przede
            wszystkim o zgodę na pokazanie kilku kadrów w portfolio. Wy dostajecie reportaż w wyjątkowej
            cenie, ja pierwsze realizacje, którymi mogę (i bardzo chcę) się pochwalić.
          </p>
        </div>
      </div>
    </section>

    {/* 4.2b — EARLY BIRD · CO OBEJMUJE (Cards) + CTA — pas piaskowy ----- */}
    <section class="sec band-sand" aria-labelledby="s-includes">
      <div class="container">
        <h2 id="s-includes" class="visually-hidden">Co obejmuje oferta early bird</h2>
        <div class="sec__includes">
          <Cards items={includes} columns={3} class="sec__cards" />
        </div>
        <a class="btn sec__cta" href="#zapis">Rezerwuję termin</a>
      </div>
    </section>

    {/* 4.3 — JAK TO DZIAŁA (Process, 3) --------------------------------- */}
    <section class="sec container" aria-labelledby="s-process">
      <p class="eyebrow">Jak to działa</p>
      <h2 id="s-process" class="visually-hidden">Jak to działa — od wyboru looku do dostawy w 24 godziny</h2>
      <Process steps={steps} class="sec__process" />
    </section>

    {/* 4.4 — JEDEN LOOK (LookSwitcher) — UKRYTY do czasu realnych zdjęć
        (Krok 23, showFrames): cały komponent to demo kadru-placeholdera w 3 tonacjach.
        Treść (lede) zaktualizowana wg copy Ady — wróci, gdy wejdą prawdziwe kadry. */}
    {showFrames && (
      <section class="sec container" aria-labelledby="s-look">
        <p class="eyebrow">Jeden look</p>
        <h2 id="s-look" class="visually-hidden">Jeden ślub, jeden klimat — wybór tonacji</h2>
        <LookSwitcher
          heading="Jeden ślub, jeden klimat"
          lede="Zamiast mieszać style, wybieracie jeden klimat jeszcze przed ślubem. Dzięki temu wszystkie zdjęcia grają razem - jak jeden, przemyślany album, a nie przypadkowy zbiór kadrów. Podejrzyjcie, jak ten sam moment wygląda w każdej z tonacji."
          alt="Placeholder — kadr ślubny w wybranej tonacji"
          name="sluby-look"
          tone={2}
        />
      </section>
    )}

    {/* 4.5 — GALERIA ŚLUBY (Gallery, 6) — UKRYTA do czasu realnych zdjęć
        (Krok 23, showFrames). Wraz z sekcją znika CTA „Zobacz realizacje". */}
    {showFrames && (
      <section id="galeria" class="sec container" aria-labelledby="s-frames">
        <p class="eyebrow">Galeria</p>
        <h2 id="s-frames" class="visually-hidden">Wybrane kadry ze ślubów</h2>
        <div class="frames">
          {frames.map((f) => (
            <Gallery
              numeral={f.numeral}
              place={f.place}
              ratio={f.ratio}
              tone={f.tone}
              src={placeholderImg(f.ratio, `${f.numeral} · ${f.place}`)}
              alt={`Placeholder — kadr ślubny ${f.numeral}`}
            />
          ))}
        </div>
        <div class="frames__more">
          <a class="btn btn--ghost" href="/realizacje">Zobacz realizacje</a>
        </div>
      </section>
    )}

    {/* 4.7 — FAQ MINI (Faq, 4) — pas piaskowy (rytm) -------------------- */}
    <section class="sec band-sand" aria-labelledby="s-faq">
      <div class="container">
        <p class="eyebrow">Częste pytania</p>
        <h2 id="s-faq" class="visually-hidden">Częste pytania — śluby</h2>
        <Faq items={faq} class="sec__faq" />
      </div>
    </section>

    {/* 4.8 — FORMULARZ REZERWACJI (Form + RODO) — krem (przed stopką) --- */}
    <section id="zapis" class="sec sec--booking container" aria-labelledby="s-booking">
      <p class="eyebrow">Zgłoszenie</p>
      <h2 id="s-booking">Zarezerwuj termin</h2>
      <Form
        name="rezerwacja-slub"
        fields={bookingFields}
        submitLabel="Wyślij zgłoszenie"
        rodoText="Wyrażam zgodę na przetwarzanie moich danych osobowych w celu odpowiedzi na zgłoszenie i ustalenia terminu."
        class="sec__form"
      />
    </section>
  </main>
</BaseLayout>

<style>
  /* Rytm pionowy sekcji — spójny z index.astro i wydarzenia-biznes.astro. */
  .sec {
    padding-block: var(--space-2xl);
  }
  .sec--hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
  }
  .sec--booking {
    padding-bottom: var(--space-3xl);
  }

  .sec > .eyebrow {
    margin-bottom: var(--space-l);
  }
  .sec__cards,
  .sec__process,
  .sec__faq,
  .sec__form {
    margin-top: 0;
  }

  /* Eyebrow w pasach: terakotowy blok-statement (early bird) + piaskowy FAQ. */
  .band-accent > .container > .eyebrow,
  .band-sand > .container > .eyebrow {
    margin-bottom: var(--space-l);
  }
  .prose {
    max-width: var(--measure);
  }
  .prose h2 {
    margin-bottom: var(--space-m);
  }
  .prose p {
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }
  /* Statement na pasie akcentowym (terakota): tekst kremowy zamiast atramentu. */
  .band-accent .prose p {
    color: color-mix(in srgb, var(--c-on-accent) 88%, transparent);
  }
  /* Karty „co obejmuje" są teraz w osobnym pasie piaskowym — odstęp górny daje
     padding sekcji, więc własny margines wrappera zerujemy (inaczej dubluje). */
  .sec__includes {
    margin-top: 0;
  }
  /* Oddech przed CTA „Rezerwuję termin" — karty nie mogą kleić się do guzika. */
  .sec__cta {
    margin-top: var(--space-2xl);
  }

  /* 4.8 — nagłówek nad formularzem. */
  .sec--booking h2 {
    margin-bottom: var(--space-l);
  }

  /* 4.5 — luźna siatka galerii (spójna z index / wydarzenia). */
  .frames {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-l);
    align-items: start;
  }
  /* CTA pod galerią — kieruje do pełnego portfolio (linki case study żyją tam). */
  .frames__more {
    margin-top: var(--space-xl);
  }
</style>
