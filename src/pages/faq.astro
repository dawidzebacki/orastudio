---
// ORA.studio — FAQ (wspólne) · P2 · Krok 13 + realne treści (ORA_tresci)
// Złożona wg sekcji 7 mapy treści (7.1–7.3). Cel sekcji = lokalne SEO przez pytania.
// Pytania i odpowiedzi = REALNE (ORA_tresci). Akapit „obszar działania" (7.3) = realny
// (nośnik SEO — Gdańsk/Gdynia/Sopot, dojazd). FAQPage JSON-LD dołączony (odpowiedzi
// są już realne — schema poprawna). Dane realne z site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Faq from '../components/Faq.astro';

// 7.2 — 10 pytań pokrywających tematy z mapy (po jednym każdy). Treści realne (ORA_tresci).
const faq = [
  {
    // gdzie fotografuję (Gdańsk / Gdynia / Sopot)
    q: 'Gdzie fotografujesz — Gdańsk, Gdynia czy Sopot?',
    a: 'We wszystkich trzech. Bazuję w Trójmieście i fotografuję w Gdańsku, Gdyni i Sopocie, a także w okolicy w promieniu około 50 km. Jeśli Twoje wydarzenie albo ślub odbywa się nieco dalej, napisz — zwykle udaje się ustalić dojazd.',
  },
  {
    // kiedy dostanę zdjęcia (24h)
    q: 'Kiedy dostanę gotowe zdjęcia z reportażu?',
    a: 'Następnego dnia. Obrobiony komplet wysyłam w 24 godziny od wydarzenia. To moja podstawowa zasada — nie chcę, żeby ktokolwiek czekał tygodniami, aż emocje opadną.',
  },
  {
    // czy robisz śluby cywilne / kameralne
    q: 'Czy fotografujesz śluby cywilne i kameralne?',
    a: 'Tak, jak najbardziej. Kameralne śluby cywilne i humanistyczne świetnie pasują do dokumentalnego stylu — jest w nich dużo naturalnych, spontanicznych chwil.',
  },
  {
    // czy mogę wybrać styl/look
    q: 'Czy mogę wybrać styl i tonację zdjęć?',
    a: 'Tak. Przed wydarzeniem wybierasz jeden klimat, a ja trzymam się go na całej serii, więc wszystkie zdjęcia są spójne.',
  },
  {
    // ile zdjęć dostaję
    q: 'Ile zdjęć otrzymam z gotowego reportażu?',
    a: 'Dostajesz wyselekcjonowany zestaw najlepszych kadrów, a nie setki niemal identycznych ujęć. Dokładna liczba zależy od długości i charakteru wydarzenia — ustalamy to na początku.',
  },
  {
    // jak rezerwuję termin
    q: 'Jak zarezerwować termin fotografowania?',
    a: 'Najprościej przez formularz na stronie. Po krótkiej rozmowie potwierdzamy szczegóły i termin. Odpowiadam zwykle tego samego dnia.',
  },
  {
    // RODO / wykorzystanie wizerunku
    q: 'Jak przetwarzasz moje dane i wizerunek (RODO)?',
    a: 'Dane z formularza wykorzystuję tylko do kontaktu i ustalenia szczegółów. Zdjęcia pokazuję w portfolio za Twoją zgodą, na podstawie umowy. Szczegóły opisuje także polityka prywatności.',
  },
  {
    // faktura (Useme)
    q: 'Czy mogę otrzymać fakturę za usługę?',
    a: 'Tak. Fakturę wystawiam przez Useme, więc rozliczenie jest proste także dla firmy.',
  },
  {
    // reportaż biznesowy vs ślubny
    q: 'Czym różni się reportaż biznesowy od ślubnego?',
    a: 'Warsztat jest ten sam — dyskretny dokument i dostawa w 24 godziny. Różni się kontekst: przy biznesie skupiam się na wydarzeniu, marce i wizerunku zespołu, przy ślubach na emocjach i relacjach. Dlatego mają osobne strony.',
  },
  {
    // czy jeżdżę poza Trójmiasto (do ~50 km)
    q: 'Czy dojeżdżasz poza Trójmiasto, do ~50 km?',
    a: 'Tak. Trójmiasto to moja baza, ale dojeżdżam w promieniu około 50 km na wydarzenia firmowe i śluby. Dalsze lokalizacje — do uzgodnienia.',
  },
];

// FAQPage JSON-LD (SEO) — odpowiedzi są realne, więc schema jest poprawna.
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title="FAQ — częste pytania o reportaż"
  description="Odpowiedzi na częste pytania o reportaż z wydarzeń i kameralnych ślubów w Trójmieście (Gdańsk, Gdynia, Sopot): dostawa zdjęć, rezerwacja, dojazd, RODO i faktura."
  path="/faq"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
  <main>
    {/* 7.1 — INTRO (Text: H1 + lede) ------------------------------------ */}
    <section class="sec sec--hero container">
      <Hero
        as="h1"
        eyebrow="FAQ"
        lead="częste"
        title="pytania."
        lede="Zebrałam tu najczęstsze pytania o reportaż ślubny i firmowy w Trójmieście. Jeśli czegoś brakuje — napisz, chętnie odpowiem."
      />
    </section>

    {/* 7.2 — LISTA PYTAŃ (Faq, 10) — pierwsze rozwinięte ----------------- */}
    <section class="sec container" aria-labelledby="s-faq">
      <h2 id="s-faq" class="visually-hidden">Najczęściej zadawane pytania</h2>
      <Faq items={faq} openFirst class="sec__faq" />
    </section>

    {/* 7.3 — OBSZAR DZIAŁANIA / DOJAZD (Text — lokalne SEO) — krem ------- */}
    <section class="sec sec--area container" aria-labelledby="s-area">
      <p class="eyebrow">Obszar działania</p>
      <h2 id="s-area" class="visually-hidden">Gdzie fotografuję — Trójmiasto i okolice</h2>
      <div class="prose">
        <p>
          ORA.studio fotografuje przede wszystkim w Trójmieście — w Gdańsku, Gdyni i Sopocie —
          oraz w najbliższej okolicy w promieniu około 50 km. Dojeżdżam na wydarzenia firmowe,
          sesje biznesowe i kameralne śluby w całym regionie; gdy miejsce leży nieco dalej,
          napisz — termin i dojazd zwykle udaje się ustalić indywidualnie.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Rytm pionowy sekcji — spójny z resztą podstron. */
  .sec {
    padding-block: var(--space-2xl);
  }
  .sec--hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
  }
  .sec--area {
    padding-bottom: var(--space-3xl);
  }

  .sec > .eyebrow {
    margin-bottom: var(--space-l);
  }
  .sec__faq {
    margin-top: 0;
  }

  /* 7.3 — akapit obszaru działania. */
  .prose {
    max-width: var(--measure);
  }
  .prose p {
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }
</style>
