---
// ORA.studio — Wydarzenia / Biznes · P1 · Krok 6
// Złożona WYŁĄCZNIE z gotowych komponentów, dokładnie wg sekcji 3 mapy treści (3.1–3.8).
// Adresat: przedsiębiorca (event, backstage, headshoty, marka) — NIE para młoda.
// SEO (naturalnie, nie listą): fotograf eventowy · reportaż z konferencji · zdjęcia wizerunkowe Trójmiasto.
// Treść = lorem w długościach z mapy (sekcja 1). Tytuły kart/kroków = realne (mapa 3.2/3.3). Dane realne z site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cards from '../components/Cards.astro';
import Process from '../components/Process.astro';
import Gallery from '../components/Gallery.astro';
import Faq from '../components/Faq.astro';
import Form from '../components/Form.astro';
import { placeholderImg } from '../utils/placeholder';
import { features } from '../data/site';

// Ramki na zdjęcia (Hero + galeria) = na razie NIEWIDOCZNE — decyzja Ady (Krok 23).
// Centralna flaga w site.ts → przełącz `features.showFrames`, gdy wejdą realne kadry.
const { showFrames } = features;

// 3.2 — co fotografuję (4 karty). Treści realne (ORA_tresci).
const shoots = [
  { title: 'Śniadania i networking', desc: 'Kuluary, rozmowy, uściski dłoni. Łapię energię spotkania, a nie tylko sztywne ustawki przy roll-upie.' },
  { title: 'Konferencje i eventy', desc: 'Prelegenci, sala, reakcje publiczności. Pełny reportaż z dnia, z którego zrobisz relację i materiały na później.' },
  { title: 'Backstage i kulisy', desc: 'To, co dzieje się za sceną i między oficjalnymi punktami. Często stąd biorą się najciekawsze kadry całego wydarzenia.' },
  { title: 'Wizerunkowe i headshoty', desc: 'Naturalne portrety zespołu na stronę i LinkedIn. Bez plastikowego studia - w Waszym otoczeniu, przy normalnym świetle.' },
];

// 3.3 — jak to działa (3 kroki). Treści realne (ORA_tresci). III = „Dostawa 24h".
const steps = [
  { title: 'Ustalenia', desc: 'Mówisz mi, co i kiedy się dzieje oraz do czego potrzebujesz zdjęć. Ustalamy zakres, prawa do publikacji i klimat materiału.' },
  { title: 'Dyskretny dokument', desc: 'Pracuję cicho i nie przerywam programu. Lampa wchodzi tylko tam, gdzie naprawdę trzeba - np. do zdjęcia grupowego.' },
  { title: 'Dostawa 24h', desc: 'Wyselekcjonowane, najlepsze zdjęcia masz następnego dnia. Gotowe na social media, czy stronę firmy.' },
];

// 3.5 — galeria biznes (6 kadrów). Podpisy realne (ORA_tresci), tonacje/proporcje mieszane.
const frames = [
  { numeral: 'I', place: 'Śniadanie biznesowe, Sopot', ratio: '3 / 2', tone: 1 },
  { numeral: 'II', place: 'Konferencja, Gdańsk', ratio: '4 / 5', tone: 2 },
  { numeral: 'III', place: 'Backstage', ratio: '1 / 1', tone: 3 },
  { numeral: 'IV', place: 'Headshot', ratio: '4 / 5', tone: 1 },
  { numeral: 'V', place: 'Gdynia', ratio: '3 / 2', tone: 3 },
  { numeral: 'VI', place: 'Networking', ratio: '1 / 1', tone: 2 },
] as const;

// 3.6 — 3 punkty „co wpływa na wycenę" (ORA_tresci). Atrament, bez bursztynu.
const factors = [
  'Długość i charakter wydarzenia',
  'Liczba i typ zdjęć',
  'Dodatki: headshoty, ekspresowa selekcja i wysyłka, sesje pozowane',
];

// 3.7 — FAQ mini (4 pytania). Treści realne (ORA_tresci): dostawa · dyskrecja · RODO · zasięg.
const faq = [
  { q: 'Jak szybko dostanę zdjęcia z wydarzenia?', a: 'Standardowo następnego dnia - obrobiony komplet w 24 godziny od eventu. Jeśli kilka kadrów potrzebujesz jeszcze tego samego dnia, np. na relację na żywo, uprzedź mnie wcześniej.' },
  { q: 'Czy fotografujesz dyskretnie, żeby nie zakłócać spotkania?', a: 'Tak, to podstawa mojego stylu. Pracuję małym, cichym aparatem, najczęściej na świetle zastanym. Większość uczestników nawet nie zauważa, że robię zdjęcia.' },
  { q: 'Jak wygląda kwestia RODO i zgód uczestników?', a: 'Przy wydarzeniach z rozpoznawalnymi osobami organizator powinien uprzedzić uczestników, że obecny będzie fotograf, i mieć podstawę do publikacji wizerunku. Zakres zdjęć i prawa do nich ustalamy na początku, najlepiej mailem.' },
  { q: 'Czy fotografujesz poza Trójmiastem?', a: 'Tak. Bazuję w Trójmieście - Gdańsk, Gdynia, Sopot - i dojeżdżam w promieniu około 50 km. Dalsze lokalizacje do uzgodnienia.' },
];

// 3.8 — pola formularza brief (imię/firma · e-mail · typ + data wydarzenia · wiadomość).
// Typy wydarzeń = kategorie z 3.2 (spójność), reszta jak w komponencie Form.
const briefFields = [
  { name: 'name', label: 'Imię i firma', type: 'text', required: true, half: true },
  { name: 'email', label: 'E-mail', as: 'input', type: 'email', required: true, half: true },
  { name: 'kind', label: 'Typ wydarzenia', as: 'select', options: ['Śniadania i networking', 'Konferencje i eventy', 'Backstage i kulisy', 'Wizerunkowe i headshoty'], required: true, half: true },
  { name: 'date', label: 'Data wydarzenia', as: 'input', type: 'date', half: true },
  { name: 'message', label: 'Wiadomość', as: 'textarea', required: true },
] as const;
---

<BaseLayout
  title="Fotograf eventowy i wizerunkowy w Trójmieście - reportaż z firmowych wydarzeń | ORA.studio"
  rawTitle
  description="Reportaż z konferencji, śniadań biznesowych i eventów firmowych w Gdańsku, Gdyni, Sopocie i okolicach. Zdjęcia wizerunkowe, backstage i headshoty. Gotowy materiał w 24 godziny."
  path="/wydarzenia-biznes"
>
  <main>
    {/* 3.1 — HERO -------------------------------------------------------- */}
    <section class="sec sec--hero container">
      <Hero
        as="h1"
        eyebrow="Wydarzenia · Biznes"
        lead="wasz dzień,"
        title="uchwycony."
        lede="Reportaż z konferencji, śniadania biznesowego czy firmowego eventu w Trójmieście - a do tego zdjęcia wizerunkowe i headshoty. Materiał gotowy do publikacji w 24 godziny."
        primary={{ label: 'Zapytaj o wycenę', href: '#brief' }}
        secondary={showFrames ? { label: 'Zobacz kadry', href: '#galeria' } : undefined}
        image={showFrames ? { numeral: 'I', place: 'Konferencja', alt: 'Placeholder — kadr otwierający z wydarzenia', ratio: '4 / 5' } : undefined}
      />
    </section>

    {/* 3.2 — CO FOTOGRAFUJĘ (Cards, 4) ---------------------------------- */}
    <section class="sec container" aria-labelledby="s-shoots">
      <p class="eyebrow">Co fotografuję</p>
      <h2 id="s-shoots" class="visually-hidden">Co fotografuję — eventy, konferencje, backstage i wizerunek</h2>
      <Cards items={shoots} columns={4} class="sec__cards" />
    </section>

    {/* 3.3 — JAK TO DZIAŁA (Process, 3) — pas piaskowy (rytm) ----------- */}
    <section class="sec band-sand" aria-labelledby="s-process">
      <div class="container">
        <p class="eyebrow">Jak to działa</p>
        <h2 id="s-process" class="visually-hidden">Jak to działa — od ustaleń do dostawy w 24 godziny</h2>
        <Process steps={steps} class="sec__process" />
      </div>
    </section>

    {/* 3.4 — DLACZEGO DOKUMENT (Text) — PAS AKCENTOWY (terakota + fala, tekst kremowy) */}
    <section class="sec band-accent" aria-labelledby="s-why">
      <div class="container">
        <div class="prose">
          <h2 id="s-why">Dlaczego reportaż, a nie ustawiane zdjęcia</h2>
          <p>
            Ustawiane zdjęcia z eventu widać od razu: wymuszony uśmiech, wszyscy patrzą w obiektyw,
            niewiele się dzieje. Reportaż pokazuje, jak naprawdę wyglądało Wasze spotkanie - skupienie
            na prelekcji, rozmowy przy kawie, uśmiech, nawiązywanie więzi. Takie zdjęcia lepiej budują
            wizerunek firmy i przedsiębiorców, bo wyglądają na prawdziwe. I takie są. Staram się pracować
            na świetle zastanym i z boku, ludzie się nie denerwują, a ich emocje są szczere.
          </p>
        </div>
      </div>
    </section>

    {/* 3.5 — GALERIA BIZNES (Gallery, 6) — UKRYTA do czasu realnych zdjęć
        (Krok 23, showFrames). Wraz z sekcją znika CTA „Zobacz realizacje". */}
    {showFrames && (
      <section id="galeria" class="sec container" aria-labelledby="s-frames">
        <p class="eyebrow">Galeria biznes</p>
        <h2 id="s-frames" class="visually-hidden">Wybrane kadry z wydarzeń i sesji wizerunkowych</h2>
        <div class="frames">
          {frames.map((f) => (
            <Gallery
              numeral={f.numeral}
              place={f.place}
              ratio={f.ratio}
              tone={f.tone}
              src={placeholderImg(f.ratio, `${f.numeral} · ${f.place}`)}
              alt={`Placeholder — kadr biznesowy ${f.numeral}`}
            />
          ))}
        </div>
        <div class="frames__more">
          <a class="btn btn--ghost" href="/realizacje">Zobacz realizacje</a>
        </div>
      </section>
    )}

    {/* 3.6 — WYCENA (Text + 3 punkty + CTA) ----------------------------- */}
    <section class="sec container" aria-labelledby="s-pricing">
      <div class="prose">
        <h2 id="s-pricing">Wycena</h2>
        <p>
          Każde wydarzenie jest inne, więc nie ma jednej, uniwersalnej ceny. Wycenę przygotowuję po
          krótkiej rozmowie - liczy się długość i charakter wydarzenia, liczba zdjęć oraz to, czy
          potrzebujesz także headshotów. Fakturę wystawiam przez use.me, więc rozliczenie jest proste
          również dla firmy.
        </p>
        <ul class="factors" role="list">
          {factors.map((point) => <li class="factors__item">{point}</li>)}
        </ul>
        <a class="btn" href="#brief">Poproś o wycenę</a>
      </div>
    </section>

    {/* 3.7 — FAQ MINI (Faq, 4) — pas piaskowy (rytm) -------------------- */}
    <section class="sec band-sand" aria-labelledby="s-faq">
      <div class="container">
        <p class="eyebrow">Częste pytania</p>
        <h2 id="s-faq" class="visually-hidden">Częste pytania — wydarzenia i biznes</h2>
        <Faq items={faq} class="sec__faq" />
      </div>
    </section>

    {/* 3.8 — FORMULARZ BRIEF (Form + RODO) — krem (przed stopką) -------- */}
    <section id="brief" class="sec sec--brief container" aria-labelledby="s-brief">
      <p class="eyebrow">Brief</p>
      <h2 id="s-brief">Opowiedz o wydarzeniu</h2>
      <Form
        name="brief-wydarzenia"
        fields={briefFields}
        submitLabel="Wyślij zapytanie"
        rodoText="Zaznaczając to pole, zgadzasz się na kontakt w sprawie tego zapytania. Szczegóły:"
        class="sec__form"
      />
    </section>
  </main>
</BaseLayout>

<style>
  /* Rytm pionowy sekcji — spójny z index.astro (duże kadry i oddech). */
  .sec {
    padding-block: var(--space-2xl);
  }
  .sec--hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
  }
  .sec--brief {
    padding-bottom: var(--space-3xl);
  }

  .sec > .eyebrow {
    margin-bottom: var(--space-l);
  }
  /* Eyebrow wewnątrz pasów (Cards / FAQ na piasku) — ten sam odstęp. */
  .band-sand > .container > .eyebrow {
    margin-bottom: var(--space-l);
  }
  .sec__cards,
  .sec__process,
  .sec__faq,
  .sec__form {
    margin-top: 0;
  }

  /* Tekstowe bloki (3.4, 3.6) — kolumna tekstu, oddech. */
  .prose {
    max-width: var(--measure);
  }
  .prose h2 {
    margin-bottom: var(--space-m);
  }
  .prose p {
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }
  /* Manifest na pasie akcentowym (terakota): tekst kremowy zamiast atramentu. */
  .band-accent .prose p {
    color: color-mix(in srgb, var(--c-on-accent) 88%, transparent);
  }

  /* 3.6 — „co wpływa na wycenę": 3 krótkie punkty na hairline, atrament (bez bursztynu). */
  .factors {
    list-style: none;
    margin: var(--space-l) 0 var(--space-l);
    padding: 0;
    max-width: var(--measure);
  }
  .factors__item {
    padding-block: var(--space-s);
    border-top: 1px solid var(--c-ink-15);
    color: var(--c-ink-70);
  }
  .factors__item:last-child {
    border-bottom: 1px solid var(--c-ink-15);
  }

  /* 3.8 — nagłówek briefu nad formularzem. */
  .sec--brief h2 {
    margin-bottom: var(--space-l);
  }

  /* 3.5 — luźna siatka galerii (spójna z index). */
  .frames {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-l);
    align-items: start;
  }
  /* CTA pod galerią — kieruje do pełnego portfolio (linki case study żyją tam). */
  .frames__more {
    margin-top: var(--space-xl);
  }
</style>
