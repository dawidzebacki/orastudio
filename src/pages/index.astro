---
// ORA.studio — Strona główna (neutralna) · P1 · Krok 5
// Złożona WYŁĄCZNIE z gotowych komponentów, dokładnie wg sekcji 2 mapy treści (2.1–2.6).
// H1 NEUTRALNE — bez słowa „ślub". Rozdziela ruch na dwie równorzędne ścieżki.
// Treść = lorem w długościach z mapy (sekcja 1). Dane realne z site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cards from '../components/Cards.astro';
import Process from '../components/Process.astro';
import Gallery from '../components/Gallery.astro';
import { placeholderImg } from '../utils/placeholder';
import { site, socials, features } from '../data/site';

// Ramki na zdjęcia (Hero + galeria) = na razie NIEWIDOCZNE — decyzja Ady (Krok 23):
// dopóki nie ma realnych kadrów, nie pokazujemy placeholderów. Centralna flaga
// w site.ts → przełącz tam `features.showFrames`, gdy wejdą prawdziwe zdjęcia.
const { showFrames } = features;

// 2.2 — dwie równorzędne ścieżki (Biznes / Śluby). Treści realne (ORA_tresci).
const paths = [
  {
    title: 'Wydarzenia i biznes',
    desc: 'Śniadania, konferencje, kulisy i zdjęcia wizerunkowe. Dyskretny reportaż z firmowego dnia oraz headshoty, które dobrze wyglądają na LinkedIn.',
    href: '/wydarzenia-biznes',
    linkLabel: 'Zobacz ofertę',
  },
  {
    title: 'Śluby',
    desc: 'Piękne uroczystości bez sztywnej pozy. Trwa nabór par na sezon 2026 w cenie early bird.',
    href: '/sluby',
    linkLabel: 'Early bird 2026',
  },
];

// 2.4 — jak pracuję / dowód 24h (3 kroki). Treści realne (ORA_tresci).
const steps = [
  { title: 'Ustalamy klimat', desc: 'Przed wydarzeniem wybierasz jeden look. Trzymam się go na wszystkich zdjęciach, więc cała seria jest spójna.' },
  { title: 'Fotografuję z boku', desc: 'Pracuję dyskretnie, jak cień, małym i cichym aparatem. Nikogo nie ustawiam i nie przerywam - większość osób nawet mnie nie zauważa.' },
  { title: 'Masz zdjęcia w 24 godziny', desc: 'Obrobiony komplet dostajesz następnego dnia. Bez czekania tygodniami i bez dopłat za pośpiech.' },
];

// 2.5 — wybrane kadry (mix neutralny, 6 kadrów). Podpisy realne (ORA_tresci).
const frames = [
  { numeral: 'I', place: 'Sopot', ratio: '4 / 5', tone: 1 },
  { numeral: 'II', place: 'Konferencja, Gdynia', ratio: '1 / 1', tone: 2 },
  { numeral: 'III', place: 'Gdańsk', ratio: '4 / 5', tone: 3 },
  { numeral: 'IV', place: 'Sopot', ratio: '3 / 4', tone: 2 },
  { numeral: 'V', place: 'Śniadanie biznesowe', ratio: '1 / 1', tone: 1 },
  { numeral: 'VI', place: 'Gdynia', ratio: '4 / 5', tone: 3 },
] as const;

// JSON-LD LocalBusiness (Krok 19 — SEO). Dane realne z site.ts. Bez telefonu i adresu
// (świadomie nie podajemy). areaServed = Trójmiasto + miasta; sameAs = profile social.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: site.brand,
  description:
    'Skondensowany reportaż dokumentalny — wydarzenia, biznes i kameralne uroczystości w Trójmieście.',
  image: new URL('/og/og-default.png', site.url).href,
  url: site.url,
  email: site.email,
  founder: { '@type': 'Person', name: site.owner },
  areaServed: ['Gdańsk', 'Gdynia', 'Sopot', 'Trójmiasto'],
  serviceType: 'Fotografia reportażowa',
  sameAs: socials.map((s) => s.href),
};
---

<BaseLayout
  title="ORA.studio - reportaż dokumentalny: wydarzenia i śluby | Trójmiasto"
  rawTitle
  description="Dokumentalna fotografia wydarzeń, eventów firmowych i kameralnych ślubów w Trójmieście. Naturalne kadry bez pozowania, gotowe zdjęcia w 24 godziny."
  path="/"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <main>
    {/* 2.1 — HERO (neutralny, H1 bez „ślub") -------------------------- */}
    <section class="sec sec--hero container">
      <Hero
        as="h1"
        eyebrow="Reportaż dokumentalny · Trójmiasto"
        lead="to, co prawdziwe -"
        title="teraz."
        lede="Fotografuję wydarzenia i śluby w Trójmieście tak, jak wyglądają - bez sztucznych póz i zbędnej reżyserii. Gotowe zdjęcia dostajesz w 24 godziny."
        primary={{ label: 'Wydarzenia i biznes', href: '/wydarzenia-biznes' }}
        secondary={{ label: 'Śluby', href: '/sluby' }}
        image={showFrames ? { numeral: 'I', place: 'Trójmiasto', alt: 'Placeholder — kadr otwierający', ratio: '4 / 5' } : undefined}
      />
    </section>

    {/* 2.2 — DWIE ŚCIEŻKI (Cards, 2 równorzędne) --------------------- */}
    <section class="sec container" aria-labelledby="s-paths">
      <p class="eyebrow">Dwie ścieżki</p>
      <h2 id="s-paths" class="visually-hidden">Dwie ścieżki: wydarzenia i biznes oraz śluby</h2>
      <Cards items={paths} numbered={false} columns={2} class="sec__cards" />
    </section>

    {/* 2.3 — MANIFEST (Text) — PAS AKCENTOWY (terakota, tekst kremowy) — podgląd „więcej koloru" */}
    <section class="sec band-accent" aria-labelledby="s-manifest">
      <div class="container">
        <div class="prose">
          <h2 id="s-manifest">Czym jest skondensowany reportaż</h2>
          <p>
            Nie chodzę za Tobą cały dzień z aparatem przy twarzy. Jestem obok, kiedy coś się dzieje, i
            znikam, kiedy nie. Zamiast setek powtarzalnych zdjęć dostajesz krótszą, mocniejszą serię -
            te momenty, które faktycznie chcesz pamiętać, w jednym, spójnym klimacie wybranym wcześniej
            przez Ciebie. Zapomnijmy o niemal identycznych zdjęciach robionych seriami.
          </p>
        </div>
      </div>
    </section>

    {/* 2.4 — JAK PRACUJĘ / DOWÓD 24h (Process) — gładki pas piaskowy (fala
        przeniesiona na blok terakotowy, by nie zlewała się z gęstym tekstem). */}
    <section class="sec band-sand" aria-labelledby="s-process">
      <div class="container">
        <p class="eyebrow">Jak pracuję</p>
        <h2 id="s-process" class="visually-hidden">Jak pracuję — od ustaleń do dostawy w 24 godziny</h2>
        <Process steps={steps} class="sec__process" />
      </div>
    </section>

    {/* 2.5 — WYBRANE KADRY (Gallery, 6 kadrów) — UKRYTE do czasu realnych zdjęć
        (Krok 23, showFrames). Wraz z sekcją znika CTA „Zobacz realizacje". */}
    {showFrames && (
      <section class="sec container" aria-labelledby="s-frames">
        <p class="eyebrow">Wybrane kadry</p>
        <h2 id="s-frames" class="visually-hidden">Wybrane kadry</h2>
        <div class="frames">
          {frames.map((f) => (
            <Gallery
              numeral={f.numeral}
              place={f.place}
              ratio={f.ratio}
              tone={f.tone}
              src={placeholderImg(f.ratio, `${f.numeral} · ${f.place}`)}
              alt={`Placeholder — wybrany kadr ${f.numeral}`}
            />
          ))}
        </div>
        <div class="frames__more">
          <a class="btn btn--ghost" href="/realizacje">Zobacz realizacje</a>
        </div>
      </section>
    )}

    {/* 2.6 — CTA STOPKOWY (Hero, wariant zwięzły) — krem (przed stopką) */}
    <section class="sec sec--cta container">
      <Hero
        compact
        as="h2"
        title="Napisz, na czym Ci zależy"
        lede="Wydarzenie firmowe czy ślub - najlepiej zacząć od krótkiej rozmowy. Odpowiadam zwykle tego samego dnia."
        primary={{ label: 'Napisz do mnie', href: '/kontakt' }}
      />
    </section>
  </main>
</BaseLayout>

<style>
  /* Rytm pionowy sekcji — duże kadry i oddech (brief: nie gęste siatki). */
  .sec {
    padding-block: var(--space-2xl);
  }
  .sec--hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
  }
  .sec--cta {
    padding-block: var(--space-3xl);
  }

  /* Eyebrow sekcji + odstęp do treści komponentu. */
  .sec > .eyebrow {
    margin-bottom: var(--space-l);
  }

  .sec__cards,
  .sec__process {
    margin-top: 0;
  }

  /* 2.3 Manifest — kolumna tekstu, eyebrow-less, oddech. */
  .prose {
    max-width: var(--measure);
  }
  .prose h2 {
    margin-bottom: var(--space-m);
  }
  .prose p {
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }
  /* Manifest na pasie akcentowym (terakota): tekst kremowy zamiast atramentu.
     Akapit lekko przygaszony, nagłówek dziedziczy pełny krem z .band-accent. */
  .band-accent .prose p {
    color: color-mix(in srgb, var(--c-on-accent) 88%, transparent);
  }

  /* Eyebrow wewnątrz pasa piaskowego (Process) — ten sam odstęp co eyebrow sekcji. */
  .band-sand > .container > .eyebrow {
    margin-bottom: var(--space-l);
  }

  /* 2.5 Galeria — luźna siatka, duże kadry. */
  .frames {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-l);
    align-items: start;
  }
  /* CTA pod galerią — kieruje do pełnego portfolio (linki case study żyją tam). */
  .frames__more {
    margin-top: var(--space-xl);
  }
</style>
