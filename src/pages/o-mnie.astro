---
// ORA.studio — O mnie (wspólne) · P2 · Krok 11
// Złożona z gotowych komponentów wg sekcji 5 mapy treści (5.1–5.5).
// Wspólna dla obu ścieżek (Biznes + Śluby) — osobista, powściągliwa.
// Treść = lorem w długościach z mapy (sekcja 1). Dane realne (autorka) z site.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Cards from '../components/Cards.astro';
import { site, features } from '../data/site';

// Ramka portretu (Hero) = na razie NIEWIDOCZNA — decyzja Ady (Krok 23).
// Centralna flaga w site.ts → przełącz `features.showFrames`, gdy wejdzie zdjęcie.
const { showFrames } = features;

// 5.4 — podejście / sprzęt (3 krótkie karty). Treści realne (ORA_tresci). Numeracja rzymska.
const approach = [
  { title: 'Mały, cichy aparat', desc: 'Fotografuję lekkim sprzętem, głównie na świetle zastanym. Dzięki temu jestem mało widoczna i nikomu nie przeszkadzam.' },
  { title: 'Jeden, spójny klimat', desc: 'Tonację ustalamy wcześniej i trzymam się jej do końca - cała seria wygląda jak jedna, przemyślana całość.' },
  { title: 'Zdjęcia w 24 godziny', desc: 'Selekcję i obróbkę robię sprawdzoną metodą, więc gotowy komplet macie następnego dnia.' },
];
---

<BaseLayout
  title="O mnie - Adrianna Zębacka | ORA.studio"
  rawTitle
  description="Za ORA.studio stoi Adrianna Zębacka - skondensowany reportaż dokumentalny w Trójmieście. Powściągliwa, editorialowa estetyka: dokument, nie inscenizacja."
  path="/o-mnie"
>
  <main>
    {/* 5.1 — INTRO (Hero + portret) ------------------------------------- */}
    <section class="sec sec--hero container">
      <Hero
        as="h1"
        eyebrow="O mnie"
        lead="cześć, jestem"
        title="Ada."
        lede="Fotografuję ludzi i chwile takimi, jakie są - bez reżyserii, za to z uwagą. Stoję za ORA.studio i za obietnicą, że zdjęcia dostajecie następnego dnia."
        image={showFrames ? { alt: `Placeholder — portret: ${site.owner}`, ratio: '4 / 5' } : undefined}
      />
    </section>

    {/* 5.2 — HISTORIA (Text, 4 akapity osobiste) ------------------------ */}
    <section class="sec container" aria-labelledby="s-story">
      <p class="eyebrow">Historia</p>
      <h2 id="s-story" class="visually-hidden">Historia — jak zaczęło się ORA.studio</h2>
      <div class="prose">
        <p>
          ORA.studio zaczęło się od mojej własnej frustracji. Po swoim ślubie czekałam na zdjęcia
          prawie pół roku. Kiedy w końcu przyszły, były piękne - ale emocje tamtego dnia zdążyły już
          przygasnąć, a częściowo zastąpiły je właśnie te negatywne.
        </p>
        <p>
          Bo jedyne zdjęcia z naszego ślubu pokochałam od razu. Rozdaliśmy gościom aparaty - instaxy,
          żeby przy okazji wpisali się do księgi gości, i jednorazowe kodaki, które potem wywołaliśmy
          sami. Kiedy parę tygodni później odebraliśmy odbitki, wróciliśmy do tamtych chwil w tym
          ciepłym, retro klimacie, który grał nam w sercach przez cały dzień. Jestem analogową
          dziewczyną - kocham ten surowy, prawdziwy look i tęsknię za prostszymi czasami.
        </p>
        <p>
          Tak narodził się pomysł na skondensowany reportaż: mniej pozowania, więcej prawdziwych
          momentów i komplet zdjęć w 24 godziny - póki wszystko jest jeszcze świeże. Dziś fotografuję
          w ten sposób zarówno kameralne śluby, jak i wydarzenia firmowe w Trójmieście.
        </p>
        <p>
          Poza fotografią jeżdżę na mnóstwo koncertów, gotuję kuchnie świata i mam w domu psa i kota.
          Lubię też zajęcia dla głowy - puzzle, sudoku, nonogramy - bo mam w sobie sporo umysłu
          ścisłego: kocham matematykę, studiowałam ekonomię i pracowałam w marketingu. Ta analityczna
          strona przydaje się bardziej, niż się wydaje - pomaga mi trzymać terminy, robić rzetelne
          wyceny i rozmawiać z firmami ich językiem.
        </p>
      </div>
    </section>

    {/* 5.3 — FILOZOFIA (Text) — PAS AKCENTOWY (terakota + fala, tekst kremowy) -- */}
    <section class="sec band-accent" aria-labelledby="s-philo">
      <div class="container">
        <div class="prose">
          <h2 id="s-philo">Dokument, nie inscenizacja</h2>
          <p>
            Najbardziej lubię te kadry, których nikt nie zaplanował - przelotne spojrzenie, skryty
            uśmiech, dłoń na ramieniu. Dlatego pracuję dyskretnie i nie ustawiam ludzi przed obiektywem.
            Wierzę, że najlepsze zdjęcia powstają wtedy, kiedy o aparacie zdążycie zapomnieć, a moją rolą
            jest być obok i nacisnąć spust migawki w odpowiednim momencie.
          </p>
        </div>
      </div>
    </section>

    {/* 5.4 — PODEJŚCIE / SPRZĘT (Cards, 3) — pas piaskowy (rytm) -------- */}
    <section class="sec band-sand" aria-labelledby="s-approach">
      <div class="container">
        <p class="eyebrow">Podejście i sprzęt</p>
        <h2 id="s-approach" class="visually-hidden">Podejście i sprzęt</h2>
        <Cards items={approach} columns={3} class="sec__cards" />
      </div>
    </section>

    {/* 5.5 — CTA (Hero compact) — krem (przed stopką) ------------------- */}
    <section class="sec sec--cta container">
      <Hero
        compact
        as="h2"
        title="Chętnie poznam Wasz pomysł"
        primary={{ label: 'Porozmawiajmy', href: '/kontakt' }}
      />
    </section>
  </main>
</BaseLayout>

<style>
  /* Rytm pionowy sekcji — spójny z index / wydarzenia / sluby. */
  .sec {
    padding-block: var(--space-2xl);
  }
  .sec--hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
  }
  .sec--cta {
    padding-block: var(--space-3xl);
  }

  .sec > .eyebrow {
    margin-bottom: var(--space-l);
  }
  /* Eyebrow wewnątrz pasa piaskowego (Historia) — ten sam odstęp. */
  .band-sand > .container > .eyebrow {
    margin-bottom: var(--space-l);
  }
  .sec__cards {
    margin-top: 0;
  }

  /* Bloki tekstowe (5.2, 5.3) — kolumna tekstu, oddech między akapitami. */
  .prose {
    max-width: var(--measure);
  }
  .prose h2 {
    margin-bottom: var(--space-m);
  }
  .prose p {
    font-size: var(--fs-lede);
    color: var(--c-ink-70);
  }
  .prose p + p {
    margin-top: var(--space-m);
  }
  /* Filozofia na pasie akcentowym (terakota): tekst kremowy zamiast atramentu. */
  .band-accent .prose p {
    color: color-mix(in srgb, var(--c-on-accent) 88%, transparent);
  }
</style>
