---
// ORA.studio — bazowy layout. Spina <head> (SEO), fonty i style globalne
// oraz globalny chrome: Nav (góra) + Footer (dół) — Krok 9.
import { site } from '../data/site';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

// Fonty body self-hosted (fontsource), bez zewnętrznych żądań: Fraunces (fallback
// display) + Outfit (body). UWAGA RODO: display Quincy CF ładuje się z Adobe Typekit
// (use.typekit.net niżej) = ZEWNĘTRZNE żądanie / transfer IP klienta — uwzględnić w
// polityce prywatności przy finalnej weryfikacji RODO.
// Fraunces Variable: oś wght + opsz (didone, wysoki kontrast) + italic do hero.
import '@fontsource-variable/fraunces/standard.css';
import '@fontsource-variable/fraunces/standard-italic.css';
// Outfit Variable: body grotesk (decyzja klientki — zamiast Neue Haas).
import '@fontsource-variable/outfit/wght.css';

import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Ścieżka kanoniczna (bez domeny), np. "/wydarzenia-biznes". */
  path?: string;
  /** Obraz OG (ścieżka względem domeny). Domyślnie brandowy placeholder. */
  image?: string;
  /** Wyłącz indeksowanie tej strony (np. /dziekujemy). */
  noindex?: boolean;
}

const {
  title,
  description = 'ORA.studio — skondensowany reportaż dokumentalny. Trójmiasto.',
  path = '/',
  image = '/og/og-default.png',
  noindex = false,
} = Astro.props;

const canonical = new URL(path, site.url).href;
const ogImage = new URL(image, site.url).href;   // OG wymaga absolutnego URL
const fullTitle = title === site.brand ? title : `${title} — ${site.brand}`;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {/* Adobe Fonts (Typekit) — Quincy CF (nagłówki display; body = Outfit self-hosted).
        Kit ograniczony do dozwolonych domen w panelu Adobe — dodaj orastudio.art
        (i localhost) w ustawieniach kitu, inaczej fonty nie zarenderują się.
        Zewnętrzne żądanie do use.typekit.net — patrz nota RODO w skrypcie wyżej. */}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/nwy4xmp.css" />

    <!-- Open Graph (spójne dane marki) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pl_PL" />
    <!-- Twitter / X (duża karta z obrazem) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f3eadb" />

    {/* No-flash dark mode (Krok 17): ustaw data-theme na <html> SYNCHRONICZNIE,
        przed pierwszym malowaniem, żeby nie mrugnęło jasnym przy ładowaniu ciemnego.
        Źródło wyboru: zapis użytkownika (localStorage) → inaczej preferencja systemu.
        is:inline = Astro nie bundluje/odracza tego skryptu (musi pójść natychmiast). */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('ora-theme');
          var theme =
            saved ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#1c1611' : '#f3eadb');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Przejdź do treści</a>
    <div class="page">
      <Nav />
      <div id="main-content">
        <slot />
      </div>
      <Footer />
    </div>
    {/* Globalny lightbox — jeden <dialog> obsługuje wszystkie kadry [data-zoom]. */}
    <Lightbox />
  </body>
</html>

<style>
  /* Skip-link — ukryty do czasu fokusu (dostępność: szybkie ominięcie nawigacji). */
  .skip-link {
    position: absolute;
    left: var(--space-s);
    top: -4rem;
    z-index: 10;
    padding: 0.6em 1em;
    background: var(--c-ink);
    color: var(--c-cream);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    text-decoration: none;
    border-radius: var(--radius);
    transition: top var(--dur) var(--ease);
  }
  .skip-link:focus-visible {
    top: var(--space-s);
  }
</style>
